{
  "rewrites": [
    {
      "source": "/api/meeting-insights/upload-url",
      "destination": "/api/meeting-insights/upload-url"
    },
    {
      "source": "/api/meeting-insights/:id",
      "destination": "/api/meeting-insights/[id]"
    },
    {
      "source": "/api/meeting-insights",
      "destination": "/api/meeting-insights/index"
    },
    { "source": "/api/chat/:path*", "destination": "/api/chat/index" },
    { "source": "/api/studio/:path*", "destination": "/api/studio/index" },
    { "source": "/api/assistant/:path*", "destination": "/api/assistant/index" },
    { "source": "/api/script-translator/:path*", "destination": "/api/script-translator/index" },
    { "source": "/api/book-translator/:path*", "destination": "/api/book-translator/index" },
    { "source": "/api/email-translator/:path*", "destination": "/api/email-translator/index" },
    { "source": "/api/audio-transcriber/:path*", "destination": "/api/audio-transcriber/index" },
    { "source": "/api/live-conversation/:path*", "destination": "/api/live-conversation/index" },
    { "source": "/api/video-generator/:path*", "destination": "/api/video-generator/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.tailwindcss.com esm.sh https://www.paypal.com https://challenges.cloudflare.com https://clerk.studio.afritranslate.co.za https://*.clerk.accounts.dev; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' *.supabase.co wss://*.supabase.co generativelanguage.googleapis.com *.clerk.accounts.dev https://challenges.cloudflare.com https://www.paypal.com https://api.paypal.com https://clerk.studio.afritranslate.co.za; frame-src https://www.paypal.com https://challenges.cloudflare.com;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://studio.afritranslate.co.za"
        }
      ]
    }
  ]
}
